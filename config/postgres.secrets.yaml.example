# PostgreSQL connection configuration for QSA.
# QSA is read-only — these connections are opened with readonly=True.
#
# Copy this file to config/postgres.secrets.yaml (gitignored) and fill
# in real passwords. See ~/repos/notes/secrets-conventions.md.

masd:
  host: localhost
  port: 5432
  database: masd
  user: mdc_user
  password: CHANGEME
  schema: masd
  connect_timeout: 10
  application_name: qsa-masd

shdb:
  host: localhost
  port: 5432
  database: shdb
  user: udc_user
  password: CHANGEME
  connect_timeout: 10
  application_name: qsa-shdb
  # Search path includes mart + shdb; QSA reads both.

mefdb:
  host: localhost
  port: 5432
  database: mefdb
  user: mef_user
  password: CHANGEME
  schema: mef
  connect_timeout: 10
  application_name: qsa-mefdb
  # Used only to read mef.universe_stock for coverage checks.
